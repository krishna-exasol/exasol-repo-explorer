# ---- GitHub ----------------------------------------------------------------
# Optional but recommended: a classic or fine-grained PAT (public_repo / read-only).
# Raises the GitHub API limit from 60/hr to 5,000/hr. The refresh uses ~8 calls.
GITHUB_TOKEN=

# ---- Upstash Redis (Vercel KV) ---------------------------------------------
# Provisioned automatically when you add the Upstash Redis integration in the
# Vercel dashboard (Storage tab). The integration injects these env vars.
# Locally, copy them from the integration's "Quickstart / .env" snippet.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# (Legacy KV naming is also supported: KV_REST_API_URL / KV_REST_API_TOKEN)

# ---- Cron protection --------------------------------------------------------
# Set any random string. Vercel Cron sends it as `Authorization: Bearer <secret>`.
# If unset, the /api/refresh route is unprotected (fine for local dev only).
CRON_SECRET=
